# =============================================================================
# DocHub — environment configuration
# =============================================================================
# Multi-tenant document Q&A. Every request has X-Tenant-Id header for isolation.

# ----- AI backend -----
AI_BACKEND=local
AI_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0
AWS_REGION=ap-southeast-1

# ----- Object storage -----
STORAGE_BACKEND=local
STORAGE_BUCKET=
STORAGE_LOCAL_DIR=./_data/uploads

# ----- Document metadata DB -----
# Options: dynamodb | postgres | sqlite
USERSTORE_BACKEND=sqlite
USERSTORE_TABLE=dochub-documents
USERSTORE_POSTGRES_URL=
USERSTORE_SQLITE_PATH=./_data/documents.db

# ----- Vector store -----
# Options: bedrock_kb | local
# When VECTOR_BACKEND=bedrock_kb you must ensure tenant_id metadata is set on every
# ingested document AND every retrieve call filters by it (the code does both).
VECTOR_BACKEND=local
VECTOR_BEDROCK_KB_ID=

# ----- Identity / Multi-tenancy -----
# Both headers required: X-User-Id (who) and X-Tenant-Id (which organization).
# In production these come from your Cognito custom attributes or JWT claims.
DEFAULT_USER_ID=test-user-001
DEFAULT_TENANT_ID=tenant-acme

LOG_LEVEL=INFO

# ----- Frontend serving (split deploy?) -----
# When SERVE_FRONTEND=true, the backend serves frontend/index.html at /.
# Set SERVE_FRONTEND=false if you deploy frontend separately to CloudFront+S3,
# Amplify, ALB+S3, or anywhere else. The frontend will then need its API_BASE
# set to point to this backend URL.
SERVE_FRONTEND=true

# ----- CORS -----
# Comma-separated list of allowed origins. Use '*' for hackathon (permissive),
# or pin to your frontend URL like 'https://d123.cloudfront.net' in production.
CORS_ORIGINS=*

# ----- Extra DB backends (optional — require requirements-optional.txt) -----
# To use DocumentDB or RDS MySQL, set USERSTORE_BACKEND accordingly AND install
# the extra deps:  pip install -r requirements-optional.txt
#
# Options: dynamodb | postgres | sqlite | documentdb | mysql
USERSTORE_MONGO_URL=                         # for documentdb (DocumentDB or MongoDB Atlas)
USERSTORE_MONGO_DB=dochub                   # database name on the MongoDB instance
USERSTORE_MONGO_TLS_CA=                      # path to RDS CA bundle for DocumentDB TLS verify
USERSTORE_MYSQL_URL=                         # for mysql (mysql://user:pw@host:3306/db)
